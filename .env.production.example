# .env.production.example
# Copy this file to .env.production on the server and fill in real values.
# This file is safe to commit — it contains NO real secrets.

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=          # use a strong password, e.g: openssl rand -base64 32
POSTGRES_DB=power_outage_api_db

# --- App Database URL ---
# Must match POSTGRES_USER, POSTGRES_PASSWORD, and POSTGRES_DB above
DATABASE_URL=postgresql://postgres:POSTGRES_PASSWORD@db:5432/power_outage_api_db

# --- Auth ---
JWT_SECRET=                 # generate with: openssl rand -base64 32
JWT_EXPIRES_IN=86400000     # 1 day in ms
BETTER_AUTH_SECRET=         # generate with: openssl rand -base64 32

# --- App ---
PORT=3004
NODE_ENV=production
